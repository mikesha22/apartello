APP_NAME=Apartello MVP
APP_ENV=dev

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/apartello

TELEGRAM_BOT_TOKEN=123456:replace_me
TELEGRAM_WEBHOOK_SECRET=super-secret-path

TRAVELLINE_WEBHOOK_SECRET=

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=mailer@example.com
SMTP_PASSWORD=replace_me
SMTP_FROM_EMAIL=Apartello <mailer@example.com>
SMTP_USE_TLS=true
SMTP_USE_SSL=false

EMAIL_OTP_SECRET=replace_with_random_secret
EMAIL_OTP_TTL_MINUTES=10
EMAIL_OTP_ATTEMPTS=5
EMAIL_OTP_RESEND_COOLDOWN_SECONDS=60
